local frktest = require("@packages/frktest")
local test = frktest.test
local check = frktest.assert.check
local roblox = require("@lune/roblox")

local vector2 = require("@src/serde/vector2")
local vector3 = require("@src/serde/vector3")
local Writer = require("@src/buffer/Writer")
local Reader = require("@src/buffer/Reader")

return function()
	test.suite("serde.vector2", function()
		test.case("zero vector", function()
			local w = Writer.new()
			local value = roblox.Vector2.new(0, 0)
			vector2.write(w, value)
			local r = Reader.new(w:toBuffer())
			check.equal(vector2.read(r), value)
		end)

		test.case("negative components", function()
			local w = Writer.new()
			local value = roblox.Vector2.new(-1.5, -2.25)
			vector2.write(w, value)
			local r = Reader.new(w:toBuffer())
			check.equal(vector2.read(r), value)
		end)

		test.case("large-magnitude components", function()
			local w = Writer.new()
			local value = roblox.Vector2.new(123456.75, -987654.5)
			vector2.write(w, value)
			local r = Reader.new(w:toBuffer())
			check.equal(vector2.read(r), value)
		end)

		test.case("unit vector", function()
			local w = Writer.new()
			local value = roblox.Vector2.new(1, 0).Unit
			vector2.write(w, value)
			local r = Reader.new(w:toBuffer())
			check.equal(vector2.read(r), value)
		end)
	end)

	test.suite("serde.vector3", function()
		test.case("zero vector", function()
			local w = Writer.new()
			local value = roblox.Vector3.new(0, 0, 0)
			vector3.write(w, value)
			local r = Reader.new(w:toBuffer())
			check.equal(vector3.read(r), value)
		end)

		test.case("negative components", function()
			local w = Writer.new()
			local value = roblox.Vector3.new(-1, -2, -3.5)
			vector3.write(w, value)
			local r = Reader.new(w:toBuffer())
			check.equal(vector3.read(r), value)
		end)

		test.case("large-magnitude components", function()
			local w = Writer.new()
			local value = roblox.Vector3.new(123456.75, -987654.5, 555555.25)
			vector3.write(w, value)
			local r = Reader.new(w:toBuffer())
			check.equal(vector3.read(r), value)
		end)

		test.case("unit vector", function()
			local w = Writer.new()
			local value = roblox.Vector3.new(1, 2, 3).Unit
			vector3.write(w, value)
			local r = Reader.new(w:toBuffer())
			check.equal(vector3.read(r), value)
		end)
	end)
end
